{
  "uid": "coverfly-overview",
  "title": "CoverFly Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Duration (p95)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 9 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests/sec",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 9 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}

